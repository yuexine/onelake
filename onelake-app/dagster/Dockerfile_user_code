FROM python:3.11-slim-bookworm

RUN apt-get update \
    && apt-get install -y --no-install-recommends openjdk-17-jre-headless procps curl \
    && rm -rf /var/lib/apt/lists/*

RUN pip install --no-cache-dir \
    dagster \
    dagster-postgres \
    pyspark==3.5.1 \
    papermill==2.6.* \
    nbconvert==7.16.* \
    ipykernel==6.29.* \
    requests==2.32.* \
    boto3==1.34.*

ENV SPARK_HOME=/usr/local/lib/python3.11/site-packages/pyspark
ENV PATH="${SPARK_HOME}/bin:${PATH}"
ENV PYSPARK_PYTHON=python

WORKDIR /opt/dagster/app
COPY definitions.py /opt/dagster/app/definitions.py

EXPOSE 4000
HEALTHCHECK --timeout=2s --start-period=5s --interval=5s --retries=20 CMD ["dagster", "api", "grpc-health-check", "-p", "4000"]
# GRAPH 模式会在每次触发前重载 code location 以读取最新流水线拓扑；
# `dagster api grpc` 不支持 reload，必须以 code-server 启动。
CMD ["dagster", "code-server", "start", "-h", "0.0.0.0", "-p", "4000", "-f", "definitions.py"]
